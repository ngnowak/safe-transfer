@startuml
title SafeTransfer - Transfer and Async Audit Flow

actor Client
participant TransferController
participant TransferService
database PostgreSQL
participant OutboxPublisher
participant AuditConsumer

Client -> TransferController : POST /api/v1/tenants/{tenantId}/transfers
TransferController -> TransferService : transfer(tenantId, idempotencyKey, request)

TransferService -> PostgreSQL : save transfer
TransferService -> PostgreSQL : save ledger debit
TransferService -> PostgreSQL : save ledger credit
TransferService -> PostgreSQL : save outbox_event(status=NEW)

TransferService --> TransferController : Transfer
TransferController --> Client : 200 OK

== Async publishing ==

OutboxPublisher -> PostgreSQL : claim retryable outbox rows\nFOR UPDATE SKIP LOCKED
PostgreSQL --> OutboxPublisher : outbox_event rows

OutboxPublisher -> AuditConsumer : consume(outboxEvent)
AuditConsumer -> PostgreSQL : insert audit_event

alt success
  OutboxPublisher -> PostgreSQL : update outbox_event\nstatus=PUBLISHED
else failure
  OutboxPublisher -> PostgreSQL : update outbox_event\nstatus=FAILED or FATAL\nretry_count = retry_count + 1
end

@enduml
